<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Workstation + не-concurrent GC. При десятках одновременных worker-процессов это
         убирает фоновый GC-поток в каждом процессе и страхует от server-GC
         (который иначе создал бы по GC-потоку на логическое ядро в КАЖДОМ процессе). -->
    <gcServer enabled="false" />
    <gcConcurrent enabled="false" />
  </runtime>
</configuration>
